{
  "name": "project-remnant-launcher",
  "version": "1.0.9",
  "description": "Standalone Electron launcher for Project Remnant — sign-in, realm picker, game-binary distribution.",
  "main": "out/main/index.js",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:win": "electron-vite build && electron-builder --win --publish never",
    "preview": "electron-vite preview",
    "release:launcher": "node --env-file=.env.release scripts/release/launcher.mjs"
  },
  "dependencies": {
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource/inter": "^5.2.8",
    "@supabase/supabase-js": "^2.105.0",
    "debug": "^4.4.3",
    "electron-updater": "^6.8.3",
    "extract-zip": "^2.0.1",
    "ms": "^2.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "socket.io-client": "^4.8.3",
    "yauzl": "^3.3.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.3.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "vite": "^6.2.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  }
}
