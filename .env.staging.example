# Launcher staging-build environment template.
# Copy to .env.staging and fill in real values. .env.staging is gitignored.
# Loaded automatically by `electron-vite build --mode staging`
# (invoked during pnpm release:launcher).

# Identity Supabase project — same as .env (one identity DB across all envs).
VITE_SUPABASE_URL=https://<your-identity-project>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-anon-key>

# Game server base URL — points at the staging Railway deployment.
VITE_GAME_API_URL=https://<your-staging-server>.up.railway.app/api/v1
