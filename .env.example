# Launcher environment variables.
#
# Copy this file to .env (gitignored) and fill in real values.
#
# These are the SAME values used by the game client today —
# project-remnant/.env  and  project-remnant/.env.staging  hold the
# identity-project URL + anon key for the renderer's Supabase client.
# See docs/systems/auth.md (in the game repo) for the three-DB model.

# Identity Supabase project — for sign-in via supabase.auth.signInWithPassword.
# Anon key only — never the service-role key (which lives only in the portal +
# Bryan's local .env.release).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Game server base URL (used for /api/v1/launcher/* endpoints in PRs 3 + 5).
# Match what project-remnant uses today as VITE_SERVER_URL.
VITE_GAME_API_URL=https://project-remnant-staging.up.railway.app/api/v1
